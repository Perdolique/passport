{
  "name": "passport",
  "version": "0.0.1",
  "description": "Passport authentication service",
  "private": true,
  "scripts": {
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate:local": "pnpm --filter backend db:migrate:local",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:push:local": "pnpm --filter backend db:push:local",
    "db:push": "pnpm --filter backend db:push",
    "db:studio": "pnpm --filter backend db:studio",
    "db:studio:local": "pnpm --filter backend db:studio:local",
    "db": "pnpm --filter backend db",
    "deploy": "pnpm --filter backend deploy",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev": "pnpm --filter backend dev",
    "lint": "oxlint --quiet --type-aware --report-unused-disable-directives-severity error",
    "test:typecheck": "pnpm -r test:typecheck",
    "test:unit:ci": "pnpm --filter backend test:unit:ci",
    "test:unit": "pnpm --filter backend test:unit",
    "update:all": "taze --recursive --interactive --include-locked"
  },
  "keywords": [],
  "author": "Pier Dolique (Perdoloque)",
  "license": "Unlicense",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "eslint-config-greenpie": "15.0.1-17",
    "oxlint": "1.42.0",
    "oxlint-tsgolint": "0.11.4",
    "taze": "19.9.2"
  }
}
