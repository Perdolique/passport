{
  "$schema": "./node_modules/oxlint/configuration_schema.json",

  "extends": [
    "./node_modules/eslint-config-greenpie/configs/oxlintrc.jsonc"
  ],

  "overrides": [
    {
      // Backend specific configuration
      "files": ["backend/**/*.ts"],

      "rules": {
        "import/no-namespace": ["error", {
          "ignore": [
            "schema",
            "valibot"
          ]
        }]
      }
    },

    {
      // Worker environment configuration
      "files": [
        "frontend/server/**/*.ts",
        "frontend/app/**/*.ts",
        "backend/src/**/*.ts"
      ],

      "env": {
        "worker": true
      }
    },

    {
    // Define Node.js environment for some files
    "files": [
      "drizzle.config.ts",
      "drizzle.local.config.ts"
    ],

    "env": {
      "node": true
    }
  },

    {
      // Test files configuration
      "files": ["**/__tests__/**/*.test.ts"],

      "rules": {
        "eslint/max-lines": "off",
        "typescript/no-explicit-any": "off",
        "no-console": "off",
        "unicorn/no-useless-undefined": "off",
        "typescript/no-unsafe-type-assertion": "off" // TODO: Remove this exception after fixing existing issues
      }
    },

    {
      // Vue files configuration
      "files": ["**/*.vue"],

      "rules": {
        "unicorn/filename-case": "off"
      }
    },

    {
      // Files with default exports
      "files": [
        "**/drizzle.config.ts",
        "**/drizzle.local.config.ts",
        "**/vitest.config.ts",
        "**/nuxt.config.ts",
        "frontend/app/middleware/*.ts",
        "frontend/server/api/**/*.ts"
      ],

      "rules": {
        "import/no-default-export": "off"
      }
    }
  ]
}
